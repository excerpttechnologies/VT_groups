# MongoDB Connection String
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/land_management

# JWT Secret for Auth (Min 32 chars - MUST BE SAME ON ALL SERVERS)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_replace_in_production

# JWT Expiration
JWT_EXPIRES_IN=7d

# API Base URL - DO NOT INCLUDE /api (lib/api.ts adds it automatically)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Admin Bootstrap (dev-only - ignored in production)
ADMIN_EMAIL=admin@vtgroups.com
ADMIN_PASSWORD=Admin@123

# Allow admin registration in production
ALLOW_ADMIN_REGISTER=false

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Seed Token
SEED_TOKEN=your-seed-token-replace-in-production
